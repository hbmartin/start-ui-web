VITE_PORT=3000

# DOCKER
# The credentials below are LOCAL-DEV DEFAULTS. Regenerate every secret before
# any non-localhost deployment — do not ship these guessable values.
DOCKER_DATABASE_PORT="5432"
DOCKER_DATABASE_NAME="startui"
DOCKER_DATABASE_USERNAME="startui"
DOCKER_DATABASE_PASSWORD="startui" # Local-dev default — regenerate for any non-localhost deployment

DOCKER_MINIO_API_PORT="9000"
DOCKER_MINIO_UI_PORT="9001"
DOCKER_MINIO_USERNAME="minioadmin"
DOCKER_MINIO_PASSWORD="minioadmin" # Local-dev default — regenerate for any non-localhost deployment
DOCKER_OTEL_COLLECTOR_PORT="4318"

# BASE URL
# Production must use https:// (http:// is only permitted for localhost).
VITE_BASE_URL="http://localhost:${VITE_PORT}"

# HTTP / PROXY
# Number of trusted reverse-proxy hops in front of the app. The client IP used
# for best-effort rate limiting is read this many hops back from the end of
# X-Forwarded-For, so attacker-supplied leftmost entries are ignored. Set it to
# match your edge: 1 for a single proxy/CDN (default), higher when chained, 0
# only when the app is directly internet-facing. Never used for authorization.
TRUSTED_PROXY_DEPTH=1

# S3
S3_BUCKET_NAME="default"
S3_HOST="127.0.0.1:${DOCKER_MINIO_API_PORT}"
S3_ACCESS_KEY_ID="startui-access-key" # Local-dev default — regenerate for any non-localhost deployment
S3_SECRET_ACCESS_KEY="startui-secret-key" # Local-dev default — regenerate for any non-localhost deployment
S3_SECURE=false
S3_FORCE_PATH_STYLE=true
# Production must use https:// (http:// is only permitted for localhost).
VITE_S3_BUCKET_PUBLIC_URL="http://${S3_HOST}/${S3_BUCKET_NAME}"

# Use the following environment variables to show the environment name.
VITE_ENV_NAME="LOCAL"
VITE_ENV_EMOJI="🚧"
VITE_ENV_COLOR="gold"

# DEPLOY TARGET
# Canonical server-side environment identifier (lowercase letters, numbers,
# underscores, dashes). Outbound calls to shared external accounts are stamped
# with it (Resend emails get a `deploy_target` tag) and inbound webhooks
# carrying a different value are acknowledged but ignored, so a staging deploy
# sharing a provider account cannot act on production callbacks (and vice
# versa). When unset it is derived: `production` in production runtimes,
# otherwise a slug of VITE_ENV_NAME (falling back to `local`). Set it
# explicitly for every non-local deployment, e.g. "staging" or "preview-42".
# DEPLOY_TARGET="staging"

# Allow visitors to create their own account from the login page.
VITE_AUTH_SIGNUP_ENABLED="true"
VITE_VISUAL_TEST="false"
# SKIP_ENV_VALIDATION is only for local/build-time tooling; production always validates runtime secrets.
# SKIP_ENV_VALIDATION="false"

# DATABASE
# Production (node-pg) requires TLS: append ?sslmode=verify-full (or at least
# ?sslmode=require) for any non-localhost host. Neon drivers are TLS by default.
DATABASE_URL="postgres://${DOCKER_DATABASE_USERNAME}:${DOCKER_DATABASE_PASSWORD}@localhost:${DOCKER_DATABASE_PORT}/${DOCKER_DATABASE_NAME}"
DATABASE_DRIVER="node-pg" # node-pg, neon-http, or neon-websocket; neon-http uses WebSocket for interactive transactions
# Optional maintenance connection for migrations. Defaults to DATABASE_URL when it is not transaction-pooled.
# DATABASE_MIGRATION_URL="postgres://${DOCKER_DATABASE_USERNAME}:${DOCKER_DATABASE_PASSWORD}@localhost:${DOCKER_DATABASE_PORT}/${DOCKER_DATABASE_NAME}"
# DATABASE_MIGRATION_DRIVER="node-pg" # node-pg or neon-websocket; neon-http migrations are rejected

# AUTH
AUTH_PROVIDER="better-auth" # better-auth for now; workos is reserved for the later AuthKit migration
AUTH_SECRET="REPLACE ME" # You can use `npx @better-auth/cli@latest secret` to a generated secret
# AUTH_ALLOWED_HOSTS="*.vercel.app" # Comma-separated list of allowed hosts for dynamic base URL (https://better-auth.com/docs/concepts/dynamic-base-url)
AUTH_SESSION_EXPIRATION_IN_SECONDS="604800" # 7 days (idle expiry; refreshed sessions still stop at AUTH_SESSION_ABSOLUTE_MAX_IN_SECONDS)
AUTH_SESSION_UPDATE_AGE_IN_SECONDS="86400" # 1 day (every 1 day the session expiration is updated)
AUTH_SESSION_FRESH_AGE_IN_SECONDS="900" # 15 min — step-up reauth window: destructive admin actions require a session this fresh, else `reauth_required` prompts re-login (lower = more prompts; Better Auth session.freshAge)
AUTH_SESSION_ABSOLUTE_MAX_IN_SECONDS="2592000" # 30 days — hard cap; a perpetually-refreshed session is rejected past this age
# Better Auth global rate limit (per identifier). Durable + shared only when UPSTASH_REDIS_* is set (see below); otherwise per-instance.
AUTH_RATE_LIMIT_WINDOW_SECONDS="60" # Fixed window, in seconds
AUTH_RATE_LIMIT_MAX="100" # Max requests per identifier per window
# Email OTP abuse controls.
AUTH_OTP_ALLOWED_ATTEMPTS="3" # Wrong-code attempts before the OTP is invalidated
AUTH_OTP_SEND_WINDOW_SECONDS="60" # Fixed window for OTP send rate limiting, in seconds
AUTH_OTP_SEND_MAX="3" # Max OTP sends per identifier per window
# AUTH_TRUSTED_ORIGINS="start-ui-native://,start-ui-native://*" # Opt-in only: extra trustedOrigins (CSRF/redirect origin allowlist). The wildcard scheme is for a companion mobile app — leave this commented out unless you ship one, so you don't broaden cross-origin trust by default.
# AUTH_ADMIN_ENDPOINTS_ENABLED="false" # Expose Better Auth's /api/auth/admin/* HTTP endpoints. Off by default; app user management works regardless (it uses the server-side API directly).
# AUTH_OPENAPI_ENABLED="false" # Expose /api/auth/open-api/generate-schema and the /api/auth/reference page. Off by default to avoid disclosing the auth API surface.

# REDIS / UPSTASH (optional)
# When BOTH are set, auth uses Upstash Redis as a durable, shared secondary store
# so Better Auth rate-limit counters and session state are enforced across all
# instances (serverless/multi-instance). When unset, a per-process in-memory store
# is used — fine for a single instance, but counters are NOT shared across
# instances, so rely on an edge/WAF rate limit for multi-instance deployments.
# Production requires https:// for the REST URL (localhost is exempt).
# UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="REPLACE ME"

# GITHUB — optional "Sign in with GitHub". Uncomment and set real values from a
# GitHub OAuth App to enable; leave commented to keep GitHub login disabled.
# GITHUB_CLIENT_ID="<your-github-oauth-client-id>"
# GITHUB_CLIENT_SECRET="<your-github-oauth-client-secret>"

# EMAILS
# Required unless EMAIL_SERVER is configured for local/test SMTP delivery.
RESEND_API_KEY="REPLACE ME"
RESEND_WEBHOOK_SECRET="REPLACE ME"
RESEND_WEBHOOK_MAX_BYTES=1000000
# Optional local/test SMTP sink, for example Maildev.
# EMAIL_SERVER="smtp://127.0.0.1:1025"
EMAIL_FROM="Start UI <noreply@example.com>"

# LOGGER
LOGGER_LEVEL="info"
LOGGER_CONSOLE_MIRROR="true"
# Legacy LOGGER_PRETTY is accepted as an alias for LOGGER_CONSOLE_MIRROR.

# SENTRY (optional — leave blank to disable)
# SENTRY_DSN=""
# VITE_SENTRY_DSN=""
# SENTRY_ENVIRONMENT=""
# VITE_SENTRY_ENVIRONMENT=""
# SENTRY_ORG="" # Required only for sourcemap upload during `pnpm build`
# SENTRY_PROJECT="" # Required only for sourcemap upload during `pnpm build`
# SENTRY_AUTH_TOKEN="" # Required only for sourcemap upload during `pnpm build`
# VITE_SENTRY_TUNNEL_PATH="/api/telemetry/sentry-tunnel"

# OTEL / OBSERVABILITY (optional)
VITE_OTEL_BROWSER_ENABLED="true"
VITE_OTEL_SERVICE_NAME="start-ui-web"
# VITE_OTEL_SERVICE_VERSION=""
VITE_OTEL_ENVIRONMENT="local"
VITE_OTEL_TRACES_SAMPLE_RATE=1
VITE_TELEMETRY_DEBUG_RAW_VALUES="false"

# Server OTel exports directly to an external Collector when configured.
# Browser telemetry always posts to same-origin /api/telemetry/* routes.
# OTEL_COLLECTOR_URL="http://localhost:${DOCKER_OTEL_COLLECTOR_PORT}"
# OTEL_COLLECTOR_BEARER_TOKEN=""
OTEL_SERVICE_NAME="start-ui-web"
# OTEL_SERVICE_VERSION=""
OTEL_ENVIRONMENT="local"
OTEL_TRACES_SAMPLE_RATE=1
OTEL_LOCAL_SQLITE_ENABLED="true"
OTEL_LOCAL_SQLITE_PATH=".telemetry/telemetry.sqlite"
TELEMETRY_PROXY_MAX_BYTES=1000000
TELEMETRY_LOG_MAX_EVENTS=50
# Best-effort per-IP/min cap on the /api/telemetry/* ingest endpoints. This is
# in-memory and per-instance (weak on serverless) — use a platform/WAF rate
# limit as the primary control. The per-IP key uses TRUSTED_PROXY_DEPTH so a
# spoofed X-Forwarded-For cannot mint fresh buckets. /api/telemetry/logs also
# requires a session.
TELEMETRY_RATE_LIMIT_PER_MINUTE=600
# Require an authenticated session on the OTLP + Sentry-tunnel proxies too (the
# logs endpoint always requires one). Off by default so pre-login browser
# telemetry works; set "true" to fully lock down the telemetry proxies.
TELEMETRY_REQUIRE_AUTH="false"

# Collector profile exporters. Required when running:
# docker compose --profile observability up otel-collector
SENTRY_OTLP_ENDPOINT="https://example.ingest.sentry.io/api/project-id/otel"
SENTRY_OTLP_AUTH_HEADER="Bearer REPLACE_ME"
HONEYCOMB_OTLP_ENDPOINT="https://api.honeycomb.io"
HONEYCOMB_API_KEY="REPLACE ME"
HONEYCOMB_DATASET="start-ui-web"
